{
	"name": "omni-cli",
	"version": "0.0.0",
	"description": "Unified wrapper around Claude Code, Codex, and GitHub Copilot CLIs",
	"keywords": [
		"agent",
		"claude",
		"cli",
		"codex",
		"copilot",
		"effect"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alexanderop/omni.git"
	},
	"bin": {
		"omni": "./dist/bin.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"scripts": {
		"build": "tsc -b tsconfig.build.json",
		"dev": "tsx src/bin.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --type-aware",
		"lint:fix": "oxlint --type-aware --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"check": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test"
	},
	"dependencies": {
		"@effect/cli": "^0.75.1",
		"@effect/platform": "^0.96.1",
		"@effect/platform-node": "^0.106.0",
		"effect": "^3.21.2"
	},
	"devDependencies": {
		"@effect/vitest": "^0.29.0",
		"@types/node": "^22.10.0",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.63.0",
		"oxlint-tsgolint": "^0.22.1",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^3.2.0"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@9.15.0"
}
