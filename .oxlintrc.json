{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import", "oxc", "promise", "node"],
  "jsPlugins": ["./tooling/oxlint-plugin.js"],
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "style": "off"
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": "error",
    "no-debugger": "error",
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-throw-literal": "error",
    "no-implicit-coercion": "error",
    "no-underscore-dangle": ["error", { "allow": ["_tag"] }],

    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-misused-promises": "error",
    "typescript/no-floating-promises": "error",
    "typescript/await-thenable": "error",
    "typescript/switch-exhaustiveness-check": "error",
    "typescript/consistent-return": "off",
    "typescript/no-unsafe-argument": "error",
    "typescript/no-unsafe-assignment": "error",
    "typescript/no-unsafe-call": "error",
    "typescript/no-unsafe-return": "error",
    "typescript/no-unsafe-member-access": "error",
    "typescript/no-unnecessary-condition": "error",
    "typescript/no-unnecessary-type-assertion": "error",
    "typescript/consistent-type-assertions": ["error", { "assertionStyle": "never" }],
    "typescript/consistent-type-imports": [
      "error",
      { "prefer": "type-imports", "fixStyle": "separate-type-imports" }
    ],
    "typescript/no-import-type-side-effects": "error",
    "typescript/no-empty-object-type": "error",
    "typescript/no-unsafe-function-type": "error",
    "typescript/no-wrapper-object-types": "error",
    "typescript/ban-ts-comment": ["error", { "ts-expect-error": "allow-with-description" }],

    "import/no-cycle": ["error", { "maxDepth": 5 }],
    "import/no-duplicates": "error",
    "import/no-self-import": "error",
    "import/no-empty-named-blocks": "error",
    "import/no-unassigned-import": ["error", { "allow": ["**/*.css", "**/*.scss"] }],

    "unicorn/prefer-node-protocol": "error",
    "unicorn/prefer-top-level-await": "error",
    "unicorn/prefer-string-starts-ends-with": "error",
    "unicorn/prefer-includes": "error",
    "unicorn/prefer-array-flat-map": "error",
    "unicorn/prefer-optional-catch-binding": "error",
    "unicorn/no-useless-undefined": "error",
    "unicorn/throw-new-error": "error",
    "unicorn/error-message": "error",

    "promise/no-return-wrap": "error",
    "promise/param-names": "error",
    "promise/no-new-statics": "error",

    "node/no-exports-assign": "error",
    "node/no-new-require": "error",

    "omni/import-extensions": "error",
    "omni/no-disable-validation": "error",
    "omni/no-sql-type-parameter": "error",
    "omni/prefer-option-from-nullable": "error",
    "omni/pipe-max-arguments": "error",
    "omni/no-effect-asvoid": "error",
    "omni/no-effect-ignore": "error",
    "omni/no-effect-catchallcause": "error",
    "omni/no-service-option": "error",
    "omni/no-silent-error-swallow": "error",
    "omni/no-void-expression": "error",
    "omni/no-nested-layer-provide": "error"
  },
  "ignorePatterns": ["**/node_modules/**", "**/dist/**", "**/*.tsbuildinfo", "tooling/**"],
  "overrides": [
    {
      "files": ["src/**"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "rules": {
        "no-console": "off",
        "typescript/no-explicit-any": "off",
        "typescript/no-non-null-assertion": "off"
      }
    }
  ]
}
